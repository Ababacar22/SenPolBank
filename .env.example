# ============================================
# SenPolBank — Variables d'environnement
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ababacar
POSTGRES_PASSWORD=
POSTGRES_DB=senpolbank

# URL Prisma (construite à partir des variables ci-dessus)
DATABASE_URL=postgresql://ababacar@localhost:5432/senpolbank

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis

# === MongoDB ===
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=senpolbank
MONGO_PASSWORD=changeme_mongo
MONGO_DB=senpolbank_audit

# === JWT ===
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
JWT_EXPIRATION=3600

# === Application ===
NODE_ENV=development
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173
