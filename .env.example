# ============================================
# SenPolBank — Variables d'environnement
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=senpolbank
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=senpolbank

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis

# === MongoDB ===
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=senpolbank
MONGO_PASSWORD=changeme_mongo
MONGO_DB=senpolbank_audit

# === JWT ===
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
JWT_EXPIRATION=3600

# === Application ===
NODE_ENV=development
API_GATEWAY_PORT=3000
