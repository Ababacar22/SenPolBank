// ==============================================
// SenPolBank — Auth Service — Prisma Schema
// ==============================================
// Ce fichier définit le modèle de données pour
// l'authentification. Prisma génère automatiquement
// le client TypeScript et les migrations SQL.
//
// POURQUOI Prisma ?
// - Type-safe : les requêtes sont vérifiées à la compilation
// - Migrations : gestion automatique du schéma SQL
// - Studio : interface web pour explorer la BDD
// ==============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Rôles disponibles dans la plateforme SenPolBank
/// - CITIZEN : citoyen qui signale des fraudes
/// - POLICE  : agent de police qui valide les plaintes
/// - BANK    : opérateur bancaire qui bloque les comptes
/// - ADMIN   : administrateur système
enum Role {
  CITIZEN
  POLICE
  BANK
  ADMIN
}

/// Statut de vérification d'identité (KYC)
enum KycStatus {
  NONE        // Aucun document soumis
  PENDING     // Document soumis, en attente de vérification
  VERIFIED    // Identité vérifiée
  REJECTED    // Document rejeté
}

/// Statut d'un signalement de fraude
enum FraudStatus {
  PENDING_POLICE // Signalé par citoyen, en attente validation police
  PENDING_BANK   // Validé par police, en attente d'action banque
  RESOLVED       // Traité et clôturé par la banque
  REJECTED       // Rejeté (plainte non valide ou erreur)
}

/// Modèle principal des utilisateurs
/// Stocke les credentials et les métadonnées de session
model User {
  id        String @id @default(uuid()) /// Identifiant unique UUID v4
  email     String @unique              /// Email unique, utilisé comme login
  password  String                      /// Hash bcrypt du mot de passe

  firstName String @map("first_name")   /// Prénom
  lastName  String @map("last_name")    /// Nom de famille
  
  phoneNumber String? @map("phone_number") /// Numéro de téléphone (optionnel)
  nationalId  String? @unique @map("national_id") /// Numéro de CNI/Passeport

  role      Role      @default(CITIZEN)    /// Rôle de l'utilisateur
  kycStatus KycStatus @default(NONE) @map("kyc_status") /// Statut KYC
  isActive  Boolean   @default(true) @map("is_active") /// Compte actif/désactivé

  /// Token de refresh hashé (null si déconnecté)
  /// Stocké hashé pour la sécurité — même si la BDD est compromise,
  /// les refresh tokens ne sont pas utilisables directement
  refreshToken String? @map("refresh_token")

  /// Relations
  reportedFrauds FraudReport[] @relation("CitizenReportedFrauds")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users") // Nom de la table en snake_case (convention PostgreSQL)
}

/// Alertes et signalements de fraudes
model FraudReport {
  id              String      @id @default(uuid())
  title           String      /// Titre court du signalement
  description     String      /// Description détaillée de la fraude
  bankName        String      @map("bank_name")    /// Nom de la banque impliquée
  bankAccount     String      @map("bank_account") /// IBAN ou no de compte concerné
  amount          Float?      /// Montant estimé de la fraude
  
  status          FraudStatus @default(PENDING_POLICE)

  citizenId       String      @map("citizen_id")
  citizen         User        @relation("CitizenReportedFrauds", fields: [citizenId], references: [id])
  
  policeId        String?     @map("police_id") // Agent de police ayant pris / validé le dossier
  policeNote      String?     @map("police_note")       /// Note de l'agent de police
  rejectionReason String?     @map("rejection_reason")  /// Motif de rejet
  validatedAt     DateTime?   @map("validated_at")      /// Date de validation par la police
  
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("fraud_reports")
}
